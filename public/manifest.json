{
  "manifest_version": 3,
  "name": "Aura - Premium New Tab",
  "version": "1.0.0",
  "description": "A breathtaking, modular, context-aware personal workspace for your browser.",
  "permissions": ["storage", "unlimitedStorage", "tabs", "bookmarks"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  }
}
